{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.appbuildinfo",

    "types": ["vite/client"],

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
